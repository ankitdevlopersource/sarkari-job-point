rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // Allow the designated admin even if email_verified is not yet propagated
      return isAuthenticated() && 
        request.auth.token.email == "Ankitkumardopta@gmail.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /blogs/{blogId} {
      // Open for read and write to allow server-side management via Client SDK
      allow read, write: if true;
    }

    match /subscribers/{subId} {
      // Open for both read and write to allow server-side management via Client SDK
      allow read, write: if true;
    }

    match /settings/{settingId} {
      // Open for read and write to allow server-side management via Client SDK
      allow read, write: if true;
    }

    match /ads/{adId} {
      // Open for read and write to allow server-side management via Client SDK
      allow read, write: if true;
    }

    match /pages/{pageId} {
      // Allow read and write to allow server-side management via Client SDK
      allow read, write: if true;
    }
  }
}
