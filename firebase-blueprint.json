{
  "entities": {
    "BlogPost": {
      "title": "BlogPost",
      "description": "A blog post about a government job update.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the blog post." },
        "slug": { "type": "string", "description": "SEO-friendly URL slug." },
        "content": { "type": "string", "description": "Markdown content of the post." },
        "category": { "type": "string", "description": "Job category (e.g., Central, State, Bank, SSC)." },
        "state": { "type": "string", "description": "State name if it's a state-level job." },
        "thumbnail": { "type": "string", "description": "URL to the thumbnail image." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "views": { "type": "number", "description": "Number of views." },
        "metaTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "isPublished": { "type": "boolean" },
        "jobSourceUrl": { "type": "string" }
      },
      "required": ["title", "slug", "content", "category", "isPublished"]
    },
    "AdminConfig": {
      "title": "AdminConfig",
      "description": "Global settings for the platform.",
      "type": "object",
      "properties": {
        "lastScrapeTime": { "type": "string", "format": "date-time" },
        "adminEmail": { "type": "string" },
        "heroBgImage": { "type": "string", "description": "Dynamic background image URL for the Hero section." }
      }
    },
    "Ad": {
      "title": "Ad",
      "description": "Popup advertisement configuration.",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string", "description": "URL of the ad image." },
        "linkUrl": { "type": "string", "description": "Destination URL when clicking the ad." },
        "showOnHome": { "type": "boolean", "description": "Whether to show as a popup on the home page." },
        "showOnBlog": { "type": "boolean", "description": "Whether to show as a popup on blog post pages." },
        "isActive": { "type": "boolean", "description": "Whether the ad is currently active." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["imageUrl", "isActive"]
    },
    "SocialLinks": {
      "title": "SocialLinks",
      "description": "URLs for social media channels like WhatsApp and Telegram.",
      "type": "object",
      "properties": {
        "whatsapp": { "type": "string" },
        "telegram": { "type": "string" }
      }
    },
    "StaticPage": {
      "title": "StaticPage",
      "description": "Content for static pages like About, Contact, etc.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "content": { "type": "string", "description": "Markdown content for the page." },
        "metaTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content"]
    }
  },
  "firestore": {
    "/blogs/{blogId}": {
      "schema": "BlogPost",
      "description": "Collection of job update blog posts."
    },
    "/pages/{pageId}": {
      "schema": "StaticPage",
      "description": "Content for static pages (about, contact, privacy, disclaimer)."
    },
    "/settings/admin": {
      "schema": "AdminConfig",
      "description": "Admin configuration settings."
    },
    "/settings/social": {
      "schema": "SocialLinks",
      "description": "Social media channel links."
    },
    "/ads/{adId}": {
      "schema": "Ad",
      "description": "Collection of popup advertisements."
    }
  }
}
